# .env.example
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Optional: comma-separated allowed browser Origins for API CORS (e.g. https://app.example.com,http://localhost:5173).
# Use * only in dev — reflects the request Origin. If unset, API is same-origin only.
# CORS_ORIGINS=""

# Auth
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
GOOGLE_CLIENT_ID=""
# Comma-separated emails that receive ADMIN on register / Google sign-up (never commit real prod list to git)
ADMIN_EMAILS=""

# Payments (NOWPayments)
# In production, mock invoices are disabled unless ALLOW_MOCK_PAYMENTS=true
ALLOW_MOCK_PAYMENTS=
# Optional cap per single deposit (USD), default 100000
MAX_DEPOSIT_AMOUNT=

# Database
DATABASE_URL="file:./dev.db"

# Polymarket public APIs (optional overrides)
POLYMARKET_GAMMA_URL="https://gamma-api.polymarket.com"
POLYMARKET_CLOB_URL="https://clob.polymarket.com"
POLYMARKET_CHAIN_ID="137"
POLYMARKET_MARKETS_TTL_SEC="20"

# Polymarket trading (required only for /api/polymarket/orders/*)
POLYMARKET_PRIVATE_KEY=""
POLYMARKET_SIGNATURE_TYPE="0"
POLYMARKET_FUNDER_ADDRESS=""
POLYMARKET_API_KEY=""
POLYMARKET_API_SECRET=""
POLYMARKET_API_PASSPHRASE=""

# NOWPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
