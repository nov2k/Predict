import React, { useState, useEffect, useRef } from 'react';
import { motion, AnimatePresence, useScroll, useTransform } from 'motion/react';
import { 
  TrendingUp, 
  MessageCircle, 
  Heart, 
  Share2, 
  Bookmark, 
  ChevronUp, 
  ChevronDown,
  Wallet,
  User as UserIcon,
  Trophy,
  Plus,
  ArrowUpRight,
  CheckCircle2,
  X,
  Info,
  History,
  ArrowLeft
} from 'lucide-react';
import { 
  LineChart, 
  Line, 
  XAxis, 
  YAxis, 
  CartesianGrid, 
  Tooltip, 
  ResponsiveContainer,
  AreaChart,
  Area
} from 'recharts';
import { cn, formatCurrency, formatPrice, trackEvent } from './lib/utils';
import { useAuthStore } from './store/useAuthStore';
import { translations } from './translations';

// --- Types ---
interface Market {
  id: string;
  source?: 'local' | 'polymarket';
  externalId?: string;
  title: string;
  description: string;
  category: string;
  imageUrl: string;
  yesPercent: number;
  noPercent: number;
  totalPool: number;
  bettorsCount: number;
  expiresAt: string | null;
  tokenIds?: string[];
  outcomes?: string[];
  tickSize?: '0.1' | '0.01' | '0.001' | '0.0001';
  negRisk?: boolean;
  userLiked?: boolean;
  userSaved?: boolean;
  _count: {
    bets: number;
    comments: number;
    likes: number;
  };
}

const isPolymarket = (market: Market) =>
  market.source === 'polymarket' || market.id.startsWith('poly_');

const getOutcomeTokenId = (market: Market, outcome: 'YES' | 'NO') => {
  if (!market.tokenIds || market.tokenIds.length === 0) return null;
  const outcomes = market.outcomes ?? ['Yes', 'No'];
  const target = outcome.toLowerCase();
  const idx = outcomes.findIndex((o) => o.toLowerCase() === target);
  if (idx >= 0 && market.tokenIds[idx]) return market.tokenIds[idx];
  return outcome === 'YES' ? market.tokenIds[0] : market.tokenIds[1] ?? market.tokenIds[0];
};

// --- Components ---

const Button = ({ className, variant = 'primary', ...props }: any) => {
  const variants = {
    primary: 'bg-emerald-500 text-white hover:bg-emerald-600',
    secondary: 'bg-zinc-800 text-zinc-100 hover:bg-zinc-700',
    danger: 'bg-rose-500 text-white hover:bg-rose-600',
    outline: 'border border-zinc-700 text-zinc-300 hover:bg-zinc-800',
    ghost: 'text-zinc-400 hover:text-white hover:bg-zinc-800/50',
  };
  return (
    <button 
      className={cn(
        'px-4 py-2 rounded-xl font-medium transition-all active:scale-95 disabled:opacity-50',
        variants[variant as keyof typeof variants],
        className
      )} 
      {...props} 
    />
  );
};

const GlassCard = ({ children, className }: any) => (
  <div className={cn('bg-zinc-900/40 backdrop-blur-md border border-white/5 rounded-2xl p-4', className)}>
    {children}
  </div>
);

// --- Main App ---

type View = 'feed' | 'rank' | 'create' | 'history' | 'profile' | 'saved';

export default function App() {
  const { user, isLoggedIn, setUser, hasDoneFakeBet, setHasDoneFakeBet, language, setLanguage } = useAuthStore();
  const t = translations[language];
  const PAGE_SIZE = 40;

  const [markets, setMarkets] = useState<Market[]>([]);
  const [currentIndex, setCurrentIndex] = useState(0);
  const [marketsOffset, setMarketsOffset] = useState(0);
  const [hasMoreMarkets, setHasMoreMarkets] = useState(true);
  const [isLoadingMarkets, setIsLoadingMarkets] = useState(false);
  const [isLoadingMoreMarkets, setIsLoadingMoreMarkets] = useState(false);
  const [marketsError, setMarketsError] = useState<string | null>(null);
  const [searchInput, setSearchInput] = useState('');
  const [searchQuery, setSearchQuery] = useState('');
  const [tags, setTags] = useState<Array<{ id: string; label: string }>>([]);
  const [selectedTagId, setSelectedTagId] = useState<string>('');
  const [currentView, setCurrentView] = useState<View>('feed');
  
  const [showAuthModal, setShowAuthModal] = useState(false);
  const [showBetModal, setShowBetModal] = useState<{ market: Market; side: 'YES' | 'NO' } | null>(null);
  const [showDetail, setShowDetail] = useState<Market | null>(null);
  const [isRealMode] = useState(true);
  const [confirmBet, setConfirmBet] = useState<{ side: 'YES' | 'NO'; amount: number } | null>(null);
  const currentMarket = markets[currentIndex] ?? markets[0] ?? null;

  useEffect(() => {
    trackEvent('app_load');
  }, []);

  const fetchMarkets = async (reset: boolean) => {
    if (reset) {
      setIsLoadingMarkets(true);
      setMarketsError(null);
    } else {
      if (isLoadingMoreMarkets || !hasMoreMarkets) return;
      setIsLoadingMoreMarkets(true);
    }

    try {
      const offset = reset ? 0 : marketsOffset;
      const params = new URLSearchParams({
        limit: String(PAGE_SIZE),
        offset: String(offset),
        includePast: 'false',
      });
      if (searchQuery.trim()) params.set('search', searchQuery.trim());
      if (selectedTagId) params.set('tagId', selectedTagId);

      const res = await fetch(`/api/polymarket/markets?${params.toString()}`);
      const data = await res.json();
      if (!res.ok) {
        throw new Error(data?.error || 'Failed to load markets');
      }

      const nextMarkets: Market[] = Array.isArray(data) ? data : [];
      if (reset) {
        setMarkets(nextMarkets);
        setCurrentIndex(0);
      } else {
        setMarkets((prev) => {
          const seen = new Set(prev.map((m) => m.id));
          const appended = nextMarkets.filter((m) => !seen.has(m.id));
          return [...prev, ...appended];
        });
      }

      setMarketsOffset(offset + nextMarkets.length);
      setHasMoreMarkets(nextMarkets.length === PAGE_SIZE);
      setMarketsError(null);
    } catch (e: any) {
      setMarketsError(e?.message || 'Failed to load markets');
    } finally {
      if (reset) setIsLoadingMarkets(false);
      else setIsLoadingMoreMarkets(false);
    }
  };

  useEffect(() => {
    const timer = window.setTimeout(() => {
      setSearchQuery(searchInput.trim());
    }, 350);
    return () => window.clearTimeout(timer);
  }, [searchInput]);

  useEffect(() => {
    const loadTags = async () => {
      try {
        const res = await fetch('/api/polymarket/tags?limit=200');
        const data = await res.json();
        if (!res.ok) return;
        setTags(Array.isArray(data) ? data.slice(0, 40) : []);
      } catch {
        // Ignore tags fetch errors; search/pagination still work.
      }
    };
    loadTags();
  }, []);

  useEffect(() => {
    setMarkets([]);
    setMarketsOffset(0);
    setHasMoreMarkets(true);
    fetchMarkets(true);
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [searchQuery, selectedTagId, user?.id, isRealMode]);

  useEffect(() => {
    if (markets.length === 0) {
      if (currentIndex !== 0) setCurrentIndex(0);
      return;
    }
    if (currentIndex >= markets.length) {
      setCurrentIndex(markets.length - 1);
    }
  }, [markets.length, currentIndex]);

  useEffect(() => {
    if (
      currentView === 'feed' &&
      markets.length > 0 &&
      currentIndex >= markets.length - 3 &&
      hasMoreMarkets &&
      !isLoadingMoreMarkets
    ) {
      fetchMarkets(false);
    }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [currentIndex, currentView, hasMoreMarkets, isLoadingMoreMarkets, markets.length]);

  const handleBetClick = (market: Market, side: 'YES' | 'NO') => {
    if (!isLoggedIn && hasDoneFakeBet) {
      setShowAuthModal(true);
      trackEvent('login_wall_shown', undefined, { marketId: market.id });
      return;
    }
    setShowBetModal({ market, side });
    trackEvent('bet_click', user?.id, { marketId: market.id, side });
  };

  const onConfirmBet = async (amount: number) => {
    if (!showBetModal) return;
    
    const side = showBetModal.side;
    const market = showBetModal.market;

    if (!isLoggedIn) {
      setHasDoneFakeBet(true);
      setConfirmBet({ side, amount });
      trackEvent('fake_bet', undefined, { marketId: market.id, amount, side });
      setTimeout(() => setConfirmBet(null), 3000);
      setShowBetModal(null);
      return;
    }

    try {
      if (isPolymarket(market)) {
        const tokenId = getOutcomeTokenId(market, side);
        if (!tokenId) {
          throw new Error('No token ID for selected outcome');
        }

        const worstPrice = side === 'YES' ? market.yesPercent / 100 : market.noPercent / 100;
        const res = await fetch('/api/polymarket/orders/market', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            tokenId,
            side: 'BUY',
            amount,
            price: Math.max(0.01, Math.min(0.99, Number(worstPrice.toFixed(4)))),
            orderType: 'FOK',
            tickSize: market.tickSize,
            negRisk: market.negRisk
          })
        });
        const data = await res.json();
        if (!res.ok) {
          throw new Error(data?.error || 'Failed to place Polymarket order');
        }

        setConfirmBet({ side, amount });
        trackEvent('bet_success', user?.id, {
          marketId: market.id,
          amount,
          side,
          source: 'polymarket',
          orderId: data.orderID
        });
        setTimeout(() => setConfirmBet(null), 3000);
      } else {
        const res = await fetch('/api/bets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            userId: user?.id,
            marketId: market.id,
            amount,
            side
          })
        });
        const data = await res.json();
        if (data.bet) {
          setUser({ ...user!, balance: data.balance });
          setConfirmBet({ side, amount });
          trackEvent('bet_success', user?.id, { marketId: market.id, amount, side });
          
          // Auto-like if not already liked
          if (!market.userLiked) {
            handleLike(market.id);
          }

          setTimeout(() => setConfirmBet(null), 3000);
        }
      }
    } catch (e: any) {
      alert(e?.message || 'Failed to place bet');
      console.error(e);
    }
    setShowBetModal(null);
  };

  const handleLogin = async () => {
    const handle = `user_${Math.floor(Math.random() * 10000)}`;
    const res = await fetch('/api/auth/mock', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: `${handle}@example.com`, handle })
    });
    const data = await res.json();
    setUser(data);
    setShowAuthModal(false);
    trackEvent('login_success', data.id);
  };

  const handleSwipe = (direction: 'up' | 'down') => {
    setCurrentIndex(prev => {
      if (markets.length === 0) return 0;
      const next =
        direction === 'up'
          ? Math.min(prev + 1, markets.length - 1)
          : Math.max(prev - 1, 0);

      if (next !== prev) {
        trackEvent(direction === 'up' ? 'swipe_up' : 'swipe_down', user?.id, { index: next });
      }
      return next;
    });
  };

  const handleLike = async (marketId: string) => {
    const selected = markets.find((m) => m.id === marketId);
    if (selected && isPolymarket(selected)) return;

    if (!isLoggedIn) {
      setShowAuthModal(true);
      return;
    }

    // Optimistic update in parent state
    setMarkets(prev => prev.map(m => {
      if (m.id === marketId) {
        const newLiked = !m.userLiked;
        return {
          ...m,
          userLiked: newLiked,
          _count: {
            ...m._count,
            likes: Math.max(0, m._count.likes + (newLiked ? 1 : -1))
          }
        };
      }
      return m;
    }));

    try {
      const res = await fetch(`/api/markets/${marketId}/like`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: user?.id })
      });
      const data = await res.json();
      
      // Sync with server response if needed (optional but safer)
      setMarkets(prev => prev.map(m => {
        if (m.id === marketId) {
          return {
            ...m,
            userLiked: data.liked
          };
        }
        return m;
      }));
      if (showDetail?.id === marketId) {
        setShowDetail(prev => prev ? { ...prev, userLiked: data.liked } : null);
      }
    } catch (e) {
      // Rollback on error
      setMarkets(prev => prev.map(m => {
        if (m.id === marketId) {
          const revertedLiked = !m.userLiked;
          return {
            ...m,
            userLiked: revertedLiked,
            _count: {
              ...m._count,
              likes: Math.max(0, m._count.likes + (revertedLiked ? 1 : -1))
            }
          };
        }
        return m;
      }));
      console.error(e);
    }
  };

  const handleSave = async (marketId: string) => {
    const selected = markets.find((m) => m.id === marketId);
    if (selected && isPolymarket(selected)) return;

    if (!isLoggedIn) {
      setShowAuthModal(true);
      return;
    }

    // Optimistic update
    setMarkets(prev => prev.map(m => {
      if (m.id === marketId) {
        return { ...m, userSaved: !m.userSaved };
      }
      return m;
    }));

    try {
      const res = await fetch(`/api/markets/${marketId}/save`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: user?.id })
      });
      const data = await res.json();
      setMarkets(prev => prev.map(m => {
        if (m.id === marketId) {
          return { ...m, userSaved: data.saved };
        }
        return m;
      }));
      if (showDetail?.id === marketId) {
        setShowDetail(prev => prev ? { ...prev, userSaved: data.saved } : null);
      }
    } catch (e) {
      // Rollback
      setMarkets(prev => prev.map(m => {
        if (m.id === marketId) {
          return { ...m, userSaved: !m.userSaved };
        }
        return m;
      }));
      console.error(e);
    }
  };

  const handleShare = async (market: Market) => {
    const shareData = {
      title: market.title,
      text: `Check out this prediction market: ${market.title}`,
      url: window.location.href,
    };

    try {
      if (navigator.share) {
        await navigator.share(shareData);
      } else {
        await navigator.clipboard.writeText(window.location.href);
        alert(t.shareSuccess);
      }
    } catch (err) {
      console.error('Error sharing:', err);
    }
  };

  const renderView = () => {
    switch (currentView) {
      case 'feed':
        if (isLoadingMarkets && markets.length === 0) {
          return (
            <div className="h-full w-full flex items-center justify-center pt-20 pb-24">
              <div className="w-8 h-8 border-4 border-emerald-500 border-t-transparent rounded-full animate-spin" />
            </div>
          );
        }

        if (marketsError && markets.length === 0) {
          return (
            <div className="h-full w-full flex items-center justify-center px-6 pt-20 pb-24">
              <GlassCard className="max-w-md w-full border-rose-500/30">
                <div className="text-rose-400 font-bold mb-2">Failed to load markets</div>
                <p className="text-sm text-zinc-300">{marketsError}</p>
              </GlassCard>
            </div>
          );
        }

        if (!currentMarket) {
          return (
            <div className="h-full w-full flex items-center justify-center pt-20 pb-24 text-zinc-500">
              No markets found
            </div>
          );
        }

        return (
          <AnimatePresence mode="wait">
            <MarketCard 
              key={currentMarket.id}
              market={currentMarket}
              onBet={handleBetClick}
              onDetail={() => setShowDetail(currentMarket)}
              onSwipe={handleSwipe}
              onLike={() => handleLike(currentMarket.id)}
              onSave={() => handleSave(currentMarket.id)}
              onShare={() => handleShare(currentMarket)}
            />
          </AnimatePresence>
        );
      case 'rank':
        return <RankingView />;
      case 'create':
        return <CreateView onClose={() => setCurrentView('feed')} />;
      case 'history':
        return <HistoryView userId={user?.id} isRealMode={isRealMode} />;
      case 'profile':
        return <ProfileView user={user} onLogout={() => { useAuthStore.getState().logout(); setCurrentView('feed'); }} onSavedClick={() => setCurrentView('saved')} />;
      case 'saved':
        return <SavedView userId={user?.id} onBack={() => setCurrentView('profile')} onMarketClick={(m) => setShowDetail(m)} />;
      default:
        return null;
    }
  };

  return (
    <div className="h-screen w-full bg-black text-white overflow-hidden flex flex-col font-sans selection:bg-emerald-500/30">
      {/* Header */}
      <header className="fixed top-0 left-0 right-0 z-50 p-4 flex items-center justify-between bg-gradient-to-b from-black/80 to-transparent backdrop-blur-sm">
        <div className="flex items-center gap-2" onClick={() => setCurrentView('feed')}>
          <div className="w-8 h-8 bg-emerald-500 rounded-lg flex items-center justify-center font-bold text-black italic">P</div>
          <span className="font-bold text-xl tracking-tight hidden sm:block">Predict YolaPay</span>
        </div>
        
        <div className="flex items-center gap-3">
          <div className="px-3 py-1 rounded-full text-xs font-medium bg-emerald-500 text-black">
            {t.live}
          </div>
          
          {isLoggedIn ? (
            <div className="flex items-center gap-2 bg-zinc-900/80 px-3 py-1.5 rounded-full border border-white/5">
              <Wallet size={14} className="text-emerald-500" />
              <span className="text-sm font-bold">{formatPrice(user!.balance, language)}</span>
            </div>
          ) : (
            <Button variant="primary" className="py-1.5 text-xs rounded-full" onClick={() => setShowAuthModal(true)}>{t.login}</Button>
          )}
        </div>
      </header>

      {currentView === 'feed' && (
        <div className="fixed top-16 left-0 right-0 z-40 px-4">
          <div className="bg-black/60 backdrop-blur-md border border-white/10 rounded-2xl p-2 flex gap-2">
            <input
              value={searchInput}
              onChange={(e) => setSearchInput(e.target.value)}
              placeholder="Search Polymarket events..."
              className="flex-1 bg-zinc-900/80 border border-white/10 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-emerald-500"
            />
            <select
              value={selectedTagId}
              onChange={(e) => setSelectedTagId(e.target.value)}
              className="bg-zinc-900/80 border border-white/10 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-emerald-500 max-w-[42%]"
            >
              <option value="">All categories</option>
              {tags.map((tag) => (
                <option key={tag.id} value={tag.id}>
                  {tag.label}
                </option>
              ))}
            </select>
          </div>
        </div>
      )}

      {/* Main Content Area */}
      <main className="flex-1 relative overflow-hidden">
        {renderView()}
        {currentView === 'feed' && isLoadingMoreMarkets && (
          <div className="absolute bottom-28 left-0 right-0 flex justify-center pointer-events-none">
            <div className="px-3 py-1 rounded-full bg-zinc-900/80 border border-white/10 text-xs text-zinc-300">
              Loading more...
            </div>
          </div>
        )}
      </main>

      {/* Bottom Nav */}
      <nav className="fixed bottom-0 left-0 right-0 z-50 bg-black/80 backdrop-blur-xl border-t border-white/5 px-6 py-3 flex justify-between items-center">
        <NavButton 
          active={currentView === 'feed'} 
          icon={<TrendingUp size={24} />} 
          label={t.feed} 
          onClick={() => setCurrentView('feed')} 
        />
        <NavButton 
          active={currentView === 'rank'} 
          icon={<Trophy size={24} />} 
          label={t.rank} 
          onClick={() => setCurrentView('rank')} 
        />
        <button 
          onClick={() => setCurrentView('create')}
          className="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-black -mt-8 shadow-xl shadow-white/10 active:scale-90 transition-transform"
        >
          <Plus size={28} />
        </button>
        <NavButton 
          active={currentView === 'history'} 
          icon={<History size={24} />} 
          label={t.bets} 
          onClick={() => {
            if (!isLoggedIn) setShowAuthModal(true);
            else setCurrentView('history');
          }} 
        />
        <NavButton 
          active={currentView === 'profile'} 
          icon={<UserIcon size={24} />} 
          label={t.me} 
          onClick={() => {
            if (!isLoggedIn) setShowAuthModal(true);
            else setCurrentView('profile');
          }} 
        />
      </nav>

      {/* Modals */}
      <AnimatePresence>
        {showBetModal && (
          <BetModal 
            market={showBetModal.market} 
            side={showBetModal.side} 
            userBalance={user?.balance || 1000}
            onClose={() => setShowBetModal(null)}
            onConfirm={onConfirmBet}
          />
        )}
        {showAuthModal && (
          <AuthModal onClose={() => setShowAuthModal(false)} onLogin={handleLogin} />
        )}
        {showDetail && (
          <MarketDetail 
            market={showDetail} 
            onClose={() => setShowDetail(null)} 
            onSave={() => handleSave(showDetail.id)}
            onShare={() => handleShare(showDetail)}
          />
        )}
        {confirmBet && (
          <BetConfirmation side={confirmBet.side} amount={confirmBet.amount} />
        )}
      </AnimatePresence>
    </div>
  );
}

function NavButton({ active, icon, label, onClick }: { active: boolean; icon: React.ReactNode; label: string; onClick: () => void }) {
  return (
    <button 
      onClick={onClick}
      className={cn(
        "flex flex-col items-center gap-1 transition-colors",
        active ? "text-emerald-500" : "text-zinc-500 hover:text-zinc-300"
      )}
    >
      {icon}
      <span className="text-[10px] font-medium uppercase tracking-widest">{label}</span>
    </button>
  );
}

// --- Views ---

function RankingView() {
  const { language } = useAuthStore();
  const t = translations[language];
  const [rankings, setRankings] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetch('/api/users/rankings')
      .then(res => res.json())
      .then(data => {
        setRankings(data);
        setLoading(false);
      });
  }, []);

  return (
    <motion.div 
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      className="h-full w-full pt-20 pb-24 overflow-y-auto px-6"
    >
      <h2 className="text-3xl font-black mb-6 tracking-tighter">{t.leaderboard}</h2>
      
      {loading ? (
        <div className="flex justify-center py-12"><div className="w-8 h-8 border-4 border-emerald-500 border-t-transparent rounded-full animate-spin" /></div>
      ) : (
        <div className="space-y-3">
          {rankings.map((u, i) => (
            <GlassCard key={u.id} className="flex items-center gap-4 py-3">
              <span className={cn(
                "w-6 text-center font-black italic text-lg",
                i === 0 ? "text-yellow-400" : i === 1 ? "text-zinc-400" : i === 2 ? "text-amber-600" : "text-zinc-600"
              )}>
                {i + 1}
              </span>
              <img src={u.avatar} className="w-10 h-10 rounded-xl bg-zinc-800" />
              <div className="flex-1">
                <div className="font-bold">@{u.handle}</div>
                <div className="text-[10px] text-zinc-500 uppercase tracking-widest">{u._count.bets} {t.bets}</div>
              </div>
              <div className="text-right">
                <div className="font-black text-emerald-400">{formatPrice(u.balance, language)}</div>
                <div className="text-[10px] text-zinc-600 uppercase tracking-widest">{t.credits}</div>
              </div>
            </GlassCard>
          ))}
        </div>
      )}
    </motion.div>
  );
}

function HistoryView({ userId, isRealMode }: { userId?: string; isRealMode: boolean }) {
  const { language } = useAuthStore();
  const t = translations[language];
  const [bets, setBets] = useState<any[]>([]);
  const [openOrders, setOpenOrders] = useState<any[]>([]);
  const [tradingError, setTradingError] = useState<string | null>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const load = async () => {
      setLoading(true);
      setTradingError(null);

      if (isRealMode) {
        try {
          const [tradesRes, openOrdersRes] = await Promise.all([
            fetch('/api/polymarket/trades'),
            fetch('/api/polymarket/orders/open')
          ]);

          const tradesData = await tradesRes.json();
          const openOrdersData = await openOrdersRes.json();

          if (!tradesRes.ok) {
            throw new Error(tradesData?.error || 'Failed to load Polymarket trades');
          }
          if (!openOrdersRes.ok) {
            throw new Error(openOrdersData?.error || 'Failed to load open orders');
          }

          setBets(Array.isArray(tradesData) ? tradesData : []);
          setOpenOrders(Array.isArray(openOrdersData) ? openOrdersData : []);
        } catch (err: any) {
          setBets([]);
          setOpenOrders([]);
          setTradingError(err?.message || 'Polymarket trading is not configured yet');
        } finally {
          setLoading(false);
        }
        return;
      }

      if (!userId) {
        setBets([]);
        setLoading(false);
        return;
      }

      try {
        const res = await fetch(`/api/users/${userId}/bets`);
        const data = await res.json();
        setBets(Array.isArray(data) ? data : []);
      } finally {
        setLoading(false);
      }
    };

    load();
  }, [userId, isRealMode]);

  return (
    <motion.div 
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      className="h-full w-full pt-20 pb-24 overflow-y-auto px-6"
    >
      <h2 className="text-3xl font-black mb-6 tracking-tighter">
        {isRealMode ? 'Live Trades' : t.myBets}
      </h2>
      
      {loading ? (
        <div className="flex justify-center py-12"><div className="w-8 h-8 border-4 border-emerald-500 border-t-transparent rounded-full animate-spin" /></div>
      ) : tradingError ? (
        <GlassCard className="border-rose-500/30">
          <div className="text-rose-400 font-bold mb-2">Trading not ready</div>
          <p className="text-sm text-zinc-300 leading-relaxed">{tradingError}</p>
        </GlassCard>
      ) : bets.length === 0 ? (
        <div className="text-center py-12 text-zinc-500">
          {isRealMode ? 'No live trades yet' : t.noBets}
        </div>
      ) : (
        <div className="space-y-4">
          {isRealMode && (
            <GlassCard className="flex items-center justify-between">
              <span className="text-xs text-zinc-500 uppercase tracking-widest font-bold">Open Orders</span>
              <span className="text-xl font-black text-emerald-400">{openOrders.length}</span>
            </GlassCard>
          )}
          {bets.map(b => (
            <GlassCard key={b.id} className="flex flex-col gap-3">
              <div className="flex justify-between items-start">
                <span className={cn(
                  "px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-widest",
                  b.side === 'YES' || b.side === 'BUY'
                    ? "bg-emerald-500/20 text-emerald-400"
                    : "bg-rose-500/20 text-rose-400"
                )}>
                  {b.side}
                </span>
                <span className="text-[10px] text-zinc-600">
                  {new Date(isRealMode ? b.match_time : b.createdAt).toLocaleDateString()}
                </span>
              </div>
              <h4 className="font-bold text-sm leading-tight">
                {isRealMode ? `Asset ${String(b.asset_id).slice(0, 10)}...` : b.market.title}
              </h4>
              <div className="flex justify-between items-center pt-2 border-t border-white/5">
                <span className="text-xs text-zinc-500">
                  {isRealMode ? 'Price x Size' : t.amount}
                </span>
                <span className="font-bold">
                  {isRealMode
                    ? `${Number(b.price).toFixed(3)} x ${Number(b.size).toFixed(2)}`
                    : formatPrice(b.amount, language)}
                </span>
              </div>
            </GlassCard>
          ))}
        </div>
      )}
    </motion.div>
  );
}

